---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getPostUrlBySlug, url } from "@utils/url-utils";
import labCardImage from "@assets/images/home-card-lab.png";
import mapCardImage from "@assets/images/home-card-map.png";
import promptCardImage from "@assets/images/home-card-prompt.png";
import projectsCardImage from "@assets/images/home-card-projects.png";
import heroImage from "@assets/images/home-hero-lab.png";

interface Props {
	latestPosts: CollectionEntry<"posts">[];
}

const { latestPosts } = Astro.props;

const entries = [
	{
		title: "学习地图",
		description: "把 LLM 基础、Prompt、RAG、Agent 和部署实践组织成一条路线。",
		href: "/map/",
		icon: "material-symbols:map-outline-rounded",
		image: mapCardImage,
	},
	{
		title: "模型排名",
		description: "按场景整理主流模型、API 能力、接入方式和中文开发注意事项。",
		href: "/models/",
		icon: "material-symbols:hub-outline",
		image: mapCardImage,
	},
	{
		title: "实验室",
		description: "用可交互工具观察 token、流程、提示词和模型行为。",
		href: "/labs/",
		icon: "material-symbols:labs-outline-rounded",
		image: labCardImage,
	},
	{
		title: "Prompt 配方",
		description: "沉淀可复用模板、输入格式、输出样例和失败案例。",
		href: "/prompts/",
		icon: "material-symbols:terminal-rounded",
		image: promptCardImage,
	},
	{
		title: "实战案例",
		description: "沉淀 RAG、Agent、模型调用和部署上线的可复现项目样板。",
		href: "/projects/",
		icon: "material-symbols:edit-note-rounded",
		image: projectsCardImage,
	},
];

const experiments = [
	["Token 成本估算器", "已上线", "估算输入、输出和调用成本。"],
	["Prompt 对比器", "下一步", "比较不同提示词结构的效果。"],
	["RAG 流程演示", "计划中", "拆解切块、召回、重排和生成。"],
	["Agent 工作流", "计划中", "展示规划、工具调用和反思修正。"],
];

const path = ["理解 LLM", "选择模型", "写好 Prompt", "构建 RAG", "设计 Agent", "部署应用"];
---

<div class="space-y-4">
	<section class="relative overflow-hidden rounded-[var(--radius-large)] bg-[var(--card-bg)] min-h-[23rem] md:min-h-[26rem] px-6 py-8 md:px-10 md:py-9 onload-animation">
		<Image
			src={heroImage}
			alt="AI 实验室、知识网络和开发者工作台组成的首页主视觉"
			class="absolute inset-0 h-full w-full object-cover object-[center_42%]"
			loading="eager"
		/>
		<div class="absolute inset-0 bg-gradient-to-r from-white via-white/75 to-white/5 dark:from-[oklch(0.18_0.014_var(--hue))] dark:via-[oklch(0.18_0.014_var(--hue))]/78 dark:to-black/5"></div>
		<div class="absolute inset-x-0 bottom-0 h-36 bg-gradient-to-t from-[var(--card-bg)] to-transparent"></div>

		<div class="relative flex min-h-[18.5rem] md:min-h-[21rem] flex-col justify-between max-w-3xl">
			<div>
				<h1 class="text-4xl md:text-5xl font-bold text-90 leading-tight mb-4">LLM, Hello!</h1>
				<p class="text-lg md:text-xl text-75 leading-8 mb-6">
					面向中文开发者的 LLM 学习与实战入口。这里把学习路线、模型排名、实验工具、Prompt 配方和可复现案例放在同一个入口里。
				</p>
				<div class="flex flex-col sm:flex-row gap-3">
					<a href={url("/map/")} class="btn-regular rounded-xl h-12 px-5 font-bold justify-start sm:justify-center">
						<Icon name="material-symbols:map-outline-rounded" class="text-2xl mr-2" />
						查看学习地图
					</a>
					<a href={url("/models/")} class="btn-plain rounded-xl h-12 px-5 font-bold justify-start sm:justify-center bg-white/55 dark:bg-black/20">
						<Icon name="material-symbols:hub-outline" class="text-2xl mr-2" />
						浏览模型排名
					</a>
				</div>
			</div>

			<div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mt-7 max-w-2xl">
				{["Model API", "Prompt", "RAG", "Agent"].map((item) => (
					<div class="rounded-xl bg-white/65 dark:bg-black/25 backdrop-blur px-3 py-3 border border-white/40 dark:border-white/10">
						<div class="text-xs text-50 mb-1">正在探索</div>
						<div class="font-bold text-90">{item}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-4">
		{entries.map((entry) => (
			<a href={url(entry.href)} class="group card-base onload-animation hover:bg-[var(--btn-card-bg-hover)] active:bg-[var(--btn-card-bg-active)]">
				<div class="relative aspect-[16/10] overflow-hidden">
					<Image
						src={entry.image}
						alt={`${entry.title}视觉图`}
						class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/5 to-transparent"></div>
					<div class="absolute bottom-3 left-3 w-10 h-10 rounded-xl bg-white/80 dark:bg-black/45 backdrop-blur flex items-center justify-center text-[var(--primary)]">
						<Icon name={entry.icon} class="text-2xl" />
					</div>
				</div>
				<div class="px-5 py-5">
					<h2 class="text-xl font-bold text-90 mb-2 flex items-center">
						{entry.title}
						<Icon name="material-symbols:chevron-right-rounded" class="text-[var(--primary)] text-2xl transition group-hover:translate-x-1" />
					</h2>
					<p class="text-75 leading-7">{entry.description}</p>
				</div>
			</a>
		))}
	</section>

	<section class="grid grid-cols-1 lg:grid-cols-[1fr_1.15fr] gap-4">
		<div class="card-base px-6 py-7 md:px-8 onload-animation">
			<h2 class="text-2xl font-bold text-90 mb-5">正在构建</h2>
			<div class="space-y-3">
				{experiments.map(([title, status, description]) => (
					<div class="rounded-2xl bg-[var(--btn-regular-bg)] px-4 py-4">
						<div class="flex items-center justify-between gap-3 mb-1">
							<div class="font-bold text-90">{title}</div>
							<div class="text-xs rounded-lg px-2.5 py-1 bg-[var(--card-bg)] text-[var(--btn-content)]">{status}</div>
						</div>
						<p class="text-sm text-75 leading-6">{description}</p>
					</div>
				))}
			</div>
		</div>

		<div class="card-base px-6 py-7 md:px-8 onload-animation">
			<h2 class="text-2xl font-bold text-90 mb-5">推荐学习路径</h2>
			<div class="space-y-4">
				{path.map((item, index) => (
					<div class="flex gap-4">
						<div class="shrink-0 w-10 h-10 rounded-xl bg-[var(--btn-regular-bg)] text-[var(--primary)] flex items-center justify-center font-bold">
							{index + 1}
						</div>
						<div class="pt-1">
							<div class="font-bold text-90">{item}</div>
							<div class="text-sm text-50 mt-1">从概念理解走向可运行的工程实践。</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="card-base px-6 py-7 md:px-8 onload-animation">
		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
			<h2 class="text-2xl font-bold text-90">最新更新</h2>
			<a href={url("/archive/")} class="btn-plain rounded-xl h-10 px-4 font-bold justify-start sm:justify-center">
				查看全部文章
				<Icon name="material-symbols:chevron-right-rounded" class="text-2xl ml-1" />
			</a>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
			{latestPosts.map((post) => (
				<a href={getPostUrlBySlug(post.slug)} class="rounded-2xl bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-regular-bg-hover)] active:bg-[var(--btn-regular-bg-active)] transition px-5 py-5">
					<div class="text-xs text-50 mb-3">{post.data.published.toLocaleDateString("zh-CN")}</div>
					<h3 class="font-bold text-lg text-90 leading-7 mb-2">{post.data.title}</h3>
					<p class="text-sm text-75 leading-6 line-clamp-3">{post.data.description}</p>
				</a>
			))}
		</div>
	</section>
</div>
