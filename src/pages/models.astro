const getWidth = (score: number, max: number) => `${Math.max(6, (score / max) * 100)}%`;
---

<MainGridLayout title="模型排名">
	<div class="leaderboard-page space-y-5 pt-24 md:pt-28">
		<section class="px-1 onload-animation">
			<div>
					<h1 class="text-2xl font-bold text-90 mb-2">排行榜总览 <span class="text-base font-medium text-50">（截止 2026年7月）</span></h1>
					<p class="text-sm text-75 leading-6 max-w-4xl">
						这里汇总主流 AI 模型在文本、图像、视觉理解等不同 Arena 中的表现，方便快速查看各类任务下的领先模型。
						<a href="https://lmarena.ai/leaderboard" target="_blank" rel="noopener noreferrer" class="text-[var(--primary)] font-bold">查看官方榜单。</a>
					</p>
			</div>
		</section>

		<section class="onload-animation">
			<div class="flex flex-wrap gap-3 text-xs text-75 mb-3">
				<div class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-[oklch(0.93_0.06_85)]"></span>第一名</div>
				<div class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-[oklch(0.88_0.03_65)]"></span>第二名</div>
				<div class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm bg-[oklch(0.82_0.05_55)]"></span>第三名</div>
			</div>

			<div class="card-base overflow-x-auto px-0 py-0">
				<table class="min-w-[72rem] w-full border-collapse text-xs">
					<thead>
						<tr class="bg-[var(--btn-regular-bg)] text-50">
							<th class="text-left px-3 py-3 font-bold w-56">模型</th>
							{overviewColumns.map((column) => <th class="text-left px-3 py-3 font-bold">{column}</th>)}
						</tr>
					</thead>
					<tbody>
						{textOverview.map(([model, ...values]) => (
							<tr class="border-t border-black/5 dark:border-white/10">
								<td class="px-3 py-2 text-75 font-medium">{model}</td>
								{values.map((value) => (
									<td class:list={[
										"px-3 py-2 text-75",
										value === 1 && "bg-[oklch(0.93_0.06_85)] dark:bg-[oklch(0.35_0.07_85)]",
										value === 2 && "bg-[oklch(0.88_0.03_65)] dark:bg-[oklch(0.30_0.05_65)]",
										value === 3 && "bg-[oklch(0.82_0.05_55)] dark:bg-[oklch(0.28_0.05_55)]",
									]}>{value}</td>
								))}
							</tr>
						))}
					</tbody>
				</table>
			</div>
		</section>

		<section class="card-base px-4 py-4 md:px-5 md:py-5 onload-animation">
			<div class="flex items-center gap-2 mb-4">
				<Icon name="material-symbols:settings-suggest-outline-rounded" class="text-lg text-75" />
				<h2 class="font-bold text-90">Agent</h2>
			</div>
			<div class="space-y-2">
				{agentRows.map((row) => {
					const max = getMax(agentRows);
					return (
						<div class="grid grid-cols-[2rem_minmax(10rem,1fr)_2rem_minmax(12rem,1.6fr)_5rem] gap-3 items-center text-sm">
							<div class="h-5 w-5 rounded bg-[var(--btn-regular-bg)] text-xs text-50 flex items-center justify-center">{row.rank}</div>
							<div class="text-75 truncate">{row.name}</div>
							<div class:list={["text-xs font-black text-center", providerTone[row.provider] ?? "text-75"]}>{providerMarks[row.provider] ?? "AI"}</div>
							<div class="h-8 rounded-sm bg-[oklch(0.93_0.012_70)] dark:bg-black/25 overflow-hidden">
								<div class="h-full bg-[oklch(0.61_0.17_145)]" style={`width: ${getWidth(row.score, max)}`}></div>
							</div>
							<div class="text-right text-xs leading-4">
								<div class="font-bold text-[oklch(0.58_0.17_145)]">+ {row.score.toFixed(2)}%</div>
								<div class="text-50">{row.delta}</div>
							</div>
						</div>
					);
				})}
			</div>
			<div class="text-center mt-5">
				<a href="https://lmarena.ai/leaderboard" target="_blank" rel="noopener noreferrer" class="text-xs text-[var(--primary)] font-bold">查看全部</a>
			</div>
		</section>

		<section class="grid grid-cols-1 lg:grid-cols-2 gap-5">
			{boards.map((board) => {
				const max = getMax(board.rows);
				return (
					<article class="card-base px-4 py-4 md:px-5 md:py-5 onload-animation">
						<div class="flex items-center justify-between gap-3 mb-4">
							<div class="flex items-center gap-2 min-w-0">
								<Icon name={board.icon} class="text-lg text-75 shrink-0" />
								<h2 class="font-bold text-90 truncate">{board.title}</h2>
							</div>
							{board.filter && (
								<div class="rounded-lg bg-[var(--btn-regular-bg)] px-2.5 py-1 text-xs text-75 flex items-center gap-1">
									<span class="h-1.5 w-1.5 rounded-full bg-[oklch(0.63_0.17_35)]"></span>
									{board.filter}
									<Icon name="material-symbols:keyboard-arrow-down-rounded" class="text-base" />
								</div>
							)}
						</div>

						<div class="space-y-2">
							{board.rows.map((row) => (
								<div class="grid grid-cols-[2rem_minmax(8rem,1fr)_2rem_minmax(8rem,1.3fr)_4.6rem] gap-2 items-center text-xs">
									<div class="h-5 w-5 rounded bg-[var(--btn-regular-bg)] text-[0.65rem] text-50 flex items-center justify-center">{row.rank}</div>
									<div class="text-75 truncate">{row.name}</div>
									<div class:list={["text-[0.65rem] font-black text-center", providerTone[row.provider] ?? "text-75"]}>{providerMarks[row.provider] ?? "AI"}</div>
									<div class="h-6 rounded-sm bg-[oklch(0.93_0.012_70)] dark:bg-black/25 overflow-hidden">
										<div class="h-full bg-[oklch(0.61_0.17_145)]" style={`width: ${getWidth(row.score, max)}`}></div>
									</div>
									<div class="text-right leading-3">
										<div class="font-bold text-75">{row.score}</div>
										<div class="text-50">{row.delta}</div>
									</div>
								</div>
							))}
						</div>
						<div class="text-center mt-5">
							<a href="https://lmarena.ai/leaderboard" target="_blank" rel="noopener noreferrer" class="text-xs text-[var(--primary)] font-bold">查看全部</a>
						</div>
					</article>
				);
			})}
		</section>

	</div>
</MainGridLayout>
